# Dependencies
node_modules/
.pnp
.pnp.js

# Build
.next/
out/
dist/

# ── Env — keep every variant out of the repo (.env, .env.bak, .env.local,
#         .env.production etc). Only the placeholder example is committed. ──
.env
.env.*
!.env.example

# ── Local bootstrap state ────────────────────────────────────────────────────
# adapter.json is realm-specific — regenerated by `npm run init` per dev.
# data/ holds marker files (.bootstrapped, .invite-link, etc).
public/adapter.json
data/
scripts/.bootstrapped

# Uploads (user content)
public/uploads/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.DS_Store
.vscode/settings.json
*.swp
*.swo

# Prisma
prisma/migrations/

# TypeScript
*.tsbuildinfo
next-env.d.ts
.vercel

# Vercel
.vercel/

# Supabase CLI local stack data (volumes are managed by Docker, but the CLI
# may also write seed data + temp dirs into supabase/.temp)
supabase/.temp/
supabase/.branches/
