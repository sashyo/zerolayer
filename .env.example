# ── ZeroLayer environment template ────────────────────────────────────────────
#
# Copy to `.env` (NOT committed) and fill in by hand, or just run:
#     npm run local      — bootstraps local stack and writes .env automatically
#     npm run deploy     — pushes a hosted env var set to Vercel
#
# Never commit a populated .env. The .gitignore excludes .env and .env.*; only
# this template is tracked.

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL: the local Postgres container — `npm run local` writes the real value.
# HOSTED: Supabase pooler URL (postgres://...pooler.supabase.com:6543/postgres).
DATABASE_URL=postgresql://zerolayer:CHANGE_ME@localhost:5432/zerolayer_db

# Prisma migrations need a non-pooled connection — point at the direct host.
# Locally this is the same as DATABASE_URL.
DIRECT_URL=postgresql://zerolayer:CHANGE_ME@localhost:5432/zerolayer_db

# ── TideCloak (auth + private-key self-encryption) ────────────────────────────
TIDECLOAK_URL=http://localhost:8080
TIDECLOAK_REALM=zerolayer
TIDECLOAK_CLIENT_ID=zerolayer-app
TIDECLOAK_ADMIN_USER=admin
# Bootstrap password used by the Docker container — `npm run local` rotates this.
TIDECLOAK_ADMIN_PASSWORD=CHANGE_ME

NEXT_PUBLIC_TIDECLOAK_URL=http://localhost:8080
NEXT_PUBLIC_TIDECLOAK_REALM=zerolayer
NEXT_PUBLIC_TIDECLOAK_CLIENT_ID=zerolayer-app

# ── Supabase Realtime ─────────────────────────────────────────────────────────
# LOCAL: defaults below match the Supabase CLI's local stack. The publishable
# key is printed by `supabase start` and captured by `npm run local`.
# HOSTED: from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./public/uploads
NEXT_PUBLIC_UPLOAD_BASE_URL=http://localhost:3000/uploads
MAX_FILE_SIZE=10485760

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_WINDOW_MS=60000
